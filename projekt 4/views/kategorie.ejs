<!DOCTYPE html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet"  type="text/css"  href="/css/style.css" />
  </head>
  <body>
    <main>
      <% if (user) { %>
      <p>Zalogowany <%= user.username %>  <a href="/auth/logout">Wyloguj się</a></p>
      <% } else { %>
      <a href="/auth/login">Zaloguj się</a>
      <% } %>
      <h1><%= title %></h1>
      <ul id="kategorie">
        <% kategorie.forEach(function(kategoria){ %>
        <li><a href="/<%= kategoria.nazwa%>"><%= kategoria.nazwa%></a></li>
        <% }) %>
      </ul>
    </main>
  </body>
</html>